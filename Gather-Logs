function NetworkDiagLogs {
    Ensure-LogDir

    $logFilePath = "$outputDir\NetworkDiag.txt"
    $output      = [System.Text.StringBuilder]::new()

    $sections = [ordered]@{
        "IP CONFIGURATION"          = { ipconfig /all }
        "ROUTING TABLE"             = { route print }
        "ARP CACHE"                 = { arp -a }
        "ACTIVE CONNECTIONS"        = { netstat -ano }
        "DNS CACHE"                 = { Get-DnsClientCache | Format-Table -AutoSize | Out-String -Width 32767 }
        "NETWORK ADAPTERS"          = { Get-NetAdapter | Format-Table Name, InterfaceDescription, Status, LinkSpeed, MacAddress -AutoSize | Out-String -Width 32767 }
        "IP ADDRESSES"              = { Get-NetIPAddress | Format-Table InterfaceAlias, AddressFamily, IPAddress, PrefixLength, Type -AutoSize | Out-String -Width 32767 }
        "DNS CLIENT SERVERS"        = { Get-DnsClientServerAddress | Format-Table -AutoSize | Out-String -Width 32767 }
        "FIREWALL PROFILES"         = { Get-NetFirewallProfile | Format-Table Name, Enabled, DefaultInboundAction, DefaultOutboundAction -AutoSize | Out-String -Width 32767 }
        "NETWORK CONNECTIVITY TEST" = { Test-NetConnection -ComputerName 8.8.8.8 -InformationLevel Detailed | Out-String -Width 32767 }
    }

    foreach ($section in $sections.Keys) {
        $null = $output.AppendLine("=" * 60)
        $null = $output.AppendLine($section)
        $null = $output.AppendLine("=" * 60)
        try {
            $result = & $sections[$section]
            $null = $output.AppendLine(($result | Out-String))
        } catch {
            $null = $output.AppendLine("ERROR: $($_.Exception.Message)")
        }
        $null = $output.AppendLine()
    }

    $output.ToString() | Out-File -FilePath $logFilePath -Encoding utf8 -Force
    Write-Host "Network diagnostics saved to: $logFilePath"
}

