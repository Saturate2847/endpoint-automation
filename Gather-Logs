function ProblemDeviceLogs {
    Ensure-LogDir

    $logFilePath = "$outputDir\ProblemDevices.txt"
    $output      = [System.Text.StringBuilder]::new()

    # Devices with a non-OK status
    $problemDevices = Get-PnpDevice | Where-Object { $_.Status -ne "OK" } | Sort-Object Status, Class

    $null = $output.AppendLine("PROBLEM DEVICES REPORT")
    $null = $output.AppendLine("Generated: $(Get-Date)")
    $null = $output.AppendLine("=" * 60)
    $null = $output.AppendLine()

    if ($problemDevices) {
        $null = $output.AppendLine("DEVICES WITH ERRORS OR WARNINGS ($($problemDevices.Count) found):")
        $null = $output.AppendLine()
        $null = $output.AppendLine(($problemDevices | Format-Table Status, Class, FriendlyName, InstanceId -AutoSize | Out-String -Width 32767))

        $null = $output.AppendLine()
        $null = $output.AppendLine("DETAIL:")
        foreach ($device in $problemDevices) {
            $null = $output.AppendLine("-" * 40)
            $null = $output.AppendLine("Name   : $($device.FriendlyName)")
            $null = $output.AppendLine("Status : $($device.Status)")
            $null = $output.AppendLine("Class  : $($device.Class)")
            $null = $output.AppendLine("ID     : $($device.InstanceId)")
            $null = $output.AppendLine()
        }
    } else {
        $null = $output.AppendLine("No problem devices found. All devices report OK status.")
    }

    # Pull device-related errors from System event log (last 24h)
    $null = $output.AppendLine("=" * 60)
    $null = $output.AppendLine("DEVICE EVENTS (System Log, last 24h, Error/Warning only):")
    $null = $output.AppendLine("=" * 60)

    try {
        $deviceEvents = Get-WinEvent -FilterHashtable @{
            LogName   = "System"
            StartTime = (Get-Date).AddHours(-24)
            Level     = @(1, 2, 3)  # Critical, Error, Warning
        } -ErrorAction Stop | Where-Object { $_.ProviderName -match "PnP|driver|device|ACPI" }

        if ($deviceEvents) {
            $null = $output.AppendLine(($deviceEvents | Format-List TimeCreated, Id, LevelDisplayName, ProviderName, Message | Out-String -Width 32767))
        } else {
            $null = $output.AppendLine("No device-related errors/warnings in the last 24 hours.")
        }
    } catch {
        $null = $output.AppendLine("Could not query device events: $($_.Exception.Message)")
    }

    $output.ToString() | Out-File -FilePath $logFilePath -Encoding utf8 -Force
    Write-Host "Problem device report saved to: $logFilePath"

    if ($problemDevices) {
        Write-Host "WARNING: $($problemDevices.Count) device(s) with non-OK status found."
    }
}

