function CriticalErrorEventViewerLogs {
    Ensure-LogDir

    $timeThreshold = (Get-Date).AddHours(-24)
    $channels      = @("Application", "System", "Security")
    $allEvents     = @()

    foreach ($channel in $channels) {
        try {
            $events = Get-WinEvent -FilterHashtable @{ LogName = $channel; StartTime = $timeThreshold } -ErrorAction Stop
            if ($events) {
                $allEvents += $events | Where-Object { $_.LevelDisplayName -match "Critical|Error" }
            }
        } catch {
            Write-Host "Could not read $channel. Error: $_"
        }
    }

    if ($allEvents.Count -gt 0) {
        $tempDir = Join-Path -Path $env:TEMP -ChildPath "tempZip_EventCrit_$(Get-Random)"
        New-Item -Path $tempDir -ItemType Directory -Force | Out-Null

        try {
            $logFilePath = Join-Path -Path $tempDir -ChildPath "CriticalErrorEventViewerLogs.txt"
            $allEvents | Format-List * | Out-String -Width 32767 | Out-File -FilePath $logFilePath -Encoding utf8

            $zipFilePath = "$outputDir\CriticalErrorEventViewerLogs.zip"
            Compress-Archive -Path "$tempDir\*" -DestinationPath $zipFilePath -Force
            Write-Host "Critical/Error EventViewer logs zipped successfully: $zipFilePath ($($allEvents.Count) events)"
        } finally {
            Remove-Item -Path $tempDir -Recurse -Force -ErrorAction SilentlyContinue
        }
    } else {
        Write-Host "No Critical/Error EventViewer logs found in the past 24 hours."
    }
}

