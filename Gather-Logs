function BSODMinidumps {
    Ensure-LogDir

    $minidumpPath = "C:\Windows\Minidump"
    $memoryDump   = "C:\Windows\MEMORY.DMP"

    $tempDir = Join-Path -Path $env:TEMP -ChildPath "tempZip_BSOD_$(Get-Random)"
    New-Item -Path $tempDir -ItemType Directory -Force | Out-Null

    try {
        $anyFiles = $false

        if (Test-Path $minidumpPath) {
            $dumps = Get-ChildItem -Path $minidumpPath -Filter "*.dmp" -ErrorAction SilentlyContinue
            if ($dumps.Count -gt 0) {
                $dumps | ForEach-Object { Copy-Item -Path $_.FullName -Destination $tempDir -Force }
                Write-Host "Copied $($dumps.Count) minidump file(s)."
                $anyFiles = $true
            } else {
                Write-Host "No minidump files found in $minidumpPath"
            }
        } else {
            Write-Host "Minidump directory not found: $minidumpPath"
        }

        # Collect BSOD-related events from System log (BugCheck = Event ID 1001)
        try {
            $bsodEvents = Get-WinEvent -FilterHashtable @{ LogName = "System"; Id = 1001 } -ErrorAction Stop
            if ($bsodEvents) {
                $bsodEvents | Format-List * | Out-String -Width 32767 |
                    Out-File -FilePath "$tempDir\BSOD_Events.txt" -Encoding utf8 -Force
                Write-Host "Exported $($bsodEvents.Count) BSOD event(s) from System log."
                $anyFiles = $true
            }
        } catch {
            Write-Host "No BSOD events (ID 1001) found in System log."
        }

        if (Test-Path $memoryDump) {
            $dumpInfo = Get-Item $memoryDump
            "Memory dump found: $memoryDump`nSize: $([math]::Round($dumpInfo.Length / 1MB, 2)) MB`nLast Modified: $($dumpInfo.LastWriteTime)" |
                Out-File -FilePath "$tempDir\MEMORY_DMP_Info.txt" -Encoding utf8 -Force
            Write-Host "Memory dump info noted (file not copied due to size)."
            $anyFiles = $true
        }

        if ($anyFiles) {
            $zipFilePath = "$outputDir\BSODMinidumps.zip"
            Compress-Archive -Path "$tempDir\*" -DestinationPath $zipFilePath -Force
            Write-Host "BSOD data zipped successfully: $zipFilePath"
        } else {
            Write-Host "No BSOD data found."
        }
    } finally {
        Remove-Item -Path $tempDir -Recurse -Force -ErrorAction SilentlyContinue
    }
}

