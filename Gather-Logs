function EventViewerLogs {
    Ensure-LogDir

    $timeThreshold = (Get-Date).AddHours(-24)
    $channels      = @("Application", "System", "Security")

    $tempDir = Join-Path -Path $env:TEMP -ChildPath "tempZip_EventViewer_$(Get-Random)"
    New-Item -Path $tempDir -ItemType Directory -Force | Out-Null

    try {
        $anyFiles = $false

        foreach ($channel in $channels) {
            Write-Host "Collecting $channel events since $timeThreshold"
            $events = $null

            try {
                $events = Get-WinEvent -FilterHashtable @{ LogName = $channel; StartTime = $timeThreshold } -ErrorAction Stop
            } catch {
                Write-Host "FilterHashtable failed for $channel, falling back to simple filter"
                try {
                    $events = Get-WinEvent -LogName $channel -ErrorAction Stop |
                        Where-Object { $_.TimeCreated -ge $timeThreshold }
                } catch {
                    Write-Host "Could not read $channel. Error: $_"
                    continue
                }
            }

            if ($events -and $events.Count -gt 0) {
                $logFilePath = Join-Path -Path $tempDir -ChildPath "EventViewerLogs_$channel.txt"
                $events | Format-List * | Out-String -Width 32767 | Out-File -FilePath $logFilePath -Encoding utf8
                Write-Host "Exported $($events.Count) events from $channel"
                $anyFiles = $true
            } else {
                Write-Host "No events found in $channel since $timeThreshold"
            }
        }

        if ($anyFiles) {
            $zipFilePath = "$outputDir\EventViewerLogs_Channels.zip"
            Compress-Archive -Path "$tempDir\*" -DestinationPath $zipFilePath -Force
            Write-Host "EventViewer logs zipped successfully: $zipFilePath"
        } else {
            Write-Host "No events collected. Skipping zip."
        }
    } finally {
        Remove-Item -Path $tempDir -Recurse -Force -ErrorAction SilentlyContinue
    }
}

