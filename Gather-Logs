function NinjaStreamerPlayerLogs {
    Ensure-LogDir

    $loggedInUser     = (Get-CimInstance -Class Win32_ComputerSystem).UserName
    $loggedInUserName = $loggedInUser.Split('\')[-1]

    $ncStreamerDir = "C:\Windows\Temp"
    $ncPlayerDir   = "C:\Users\$loggedInUserName\AppData\Local\Temp"

    $timeThreshold = (Get-Date).AddHours(-24)

    function Get-LogFilesAndZip {
        param (
            [string]$sourceDir,
            [string]$pattern,
            [string]$zipName
        )

        $logFiles = Get-ChildItem -Path $sourceDir -Filter $pattern -ErrorAction SilentlyContinue |
            Where-Object { $_.LastWriteTime -ge $timeThreshold }

        if ($logFiles.Count -gt 0) {
            $zipFilePath = Join-Path -Path $outputDir -ChildPath $zipName
            $tempDir     = Join-Path -Path $env:TEMP -ChildPath "tempZip_Ninja_$(Get-Random)"

            New-Item -Path $tempDir -ItemType Directory -Force | Out-Null
            try {
                $logFiles | ForEach-Object { Copy-Item -Path $_.FullName -Destination $tempDir }
                Compress-Archive -Path "$tempDir\*" -DestinationPath $zipFilePath -Force
                Write-Host "Files zipped successfully: $zipFilePath"
            } finally {
                Remove-Item -Path $tempDir -Recurse -Force -ErrorAction SilentlyContinue
            }
        } else {
            Write-Host "No files matching '$pattern' in '$sourceDir' within the last 24 hours."
        }
    }

    Get-LogFilesAndZip -sourceDir $ncStreamerDir -pattern "NCStreamer*" -zipName "NCStreamerLogs.zip"
    Get-LogFilesAndZip -sourceDir $ncPlayerDir   -pattern "NCplayer*"  -zipName "NCPlayerLogs.zip"

    Write-Host "Process completed."
}

