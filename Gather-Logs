function CorruptionLog {
    Ensure-LogDir

    $logFilePath = "$outputDir\SFC_CorruptionSummary.log"
    $cbsLog      = "$env:windir\Logs\CBS\CBS.log"

    Write-Host "Running System File Checker (this may take several minutes)..."
    sfc /scannow | Out-Null

    Write-Host "Parsing CBS.log for corruption results..."

    $corruptionEntries = Select-String -Path $cbsLog -Pattern "corrupt", "cannot repair", "repair completed" -SimpleMatch |
        Where-Object { $_.Line -match "Repair|corrupt" }

    if ($corruptionEntries) {
        $corruptionEntries | ForEach-Object { $_.Line } |
            Out-File -FilePath $logFilePath -Encoding UTF8 -Force
        Write-Host "Corruption summary saved to: $logFilePath"
    } else {
        "No corruption entries found in CBS.log after scan." |
            Out-File -FilePath $logFilePath -Encoding UTF8 -Force
        Write-Host "No corruption found."
    }
}

