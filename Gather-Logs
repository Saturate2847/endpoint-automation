function DiskHealthLogs {
    Ensure-LogDir

    $logFilePath = "$outputDir\DiskHealth.txt"
    $output      = [System.Text.StringBuilder]::new()

    $sections = [ordered]@{
        "PHYSICAL DISK HEALTH" = {
            Get-PhysicalDisk | Format-List FriendlyName, SerialNumber, MediaType, OperationalStatus, HealthStatus, Size, BusType |
                Out-String -Width 32767
        }
        "LOGICAL DISK USAGE" = {
            Get-PSDrive -PSProvider FileSystem | Format-Table Name, Root, Used, Free, @{
                Name       = "TotalGB"
                Expression = { [math]::Round(($_.Used + $_.Free) / 1GB, 2) }
            }, @{
                Name       = "FreeGB"
                Expression = { [math]::Round($_.Free / 1GB, 2) }
            }, @{
                Name       = "UsedPct"
                Expression = {
                    $total = $_.Used + $_.Free
                    if ($total -gt 0) { "{0:N1}%" -f (($_.Used / $total) * 100) } else { "N/A" }
                }
            } -AutoSize | Out-String -Width 32767
        }
        "VOLUME INFORMATION" = {
            Get-Volume | Format-Table DriveLetter, FileSystemLabel, FileSystem, DriveType, HealthStatus, SizeRemaining, Size -AutoSize |
                Out-String -Width 32767
        }
        "DISK PARTITIONS" = {
            Get-Partition | Format-Table DiskNumber, PartitionNumber, DriveLetter, Size, Type, IsActive, IsBoot -AutoSize |
                Out-String -Width 32767
        }
        "STORAGE ERRORS (last 24h)" = {
            $threshold = (Get-Date).AddHours(-24)
            try {
                Get-WinEvent -FilterHashtable @{ LogName = "System"; ProviderName = "disk"; StartTime = $threshold } -ErrorAction Stop |
                    Format-List * | Out-String -Width 32767
            } catch {
                "No disk errors in System log in the last 24 hours."
            }
        }
    }

    foreach ($section in $sections.Keys) {
        $null = $output.AppendLine("=" * 60)
        $null = $output.AppendLine($section)
        $null = $output.AppendLine("=" * 60)
        try {
            $result = & $sections[$section]
            $null = $output.AppendLine(($result | Out-String))
        } catch {
            $null = $output.AppendLine("ERROR: $($_.Exception.Message)")
        }
        $null = $output.AppendLine()
    }

    $output.ToString() | Out-File -FilePath $logFilePath -Encoding utf8 -Force
    Write-Host "Disk health report saved to: $logFilePath"
}

