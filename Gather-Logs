function AppCrashLogs {
    Ensure-LogDir

    $werPaths = @(
        "C:\ProgramData\Microsoft\Windows\WER\ReportArchive",
        "C:\ProgramData\Microsoft\Windows\WER\ReportQueue",
        "$env:LOCALAPPDATA\Microsoft\Windows\WER\ReportArchive",
        "$env:LOCALAPPDATA\Microsoft\Windows\WER\ReportQueue"
    )

    $tempDir = Join-Path -Path $env:TEMP -ChildPath "tempZip_AppCrash_$(Get-Random)"
    New-Item -Path $tempDir -ItemType Directory -Force | Out-Null

    try {
        $anyFiles  = $false
        $threshold = (Get-Date).AddDays(-7)

        foreach ($werPath in $werPaths) {
            if (-not (Test-Path $werPath)) { continue }

            $reports = Get-ChildItem -Path $werPath -Directory -ErrorAction SilentlyContinue |
                Where-Object { $_.LastWriteTime -ge $threshold }

            foreach ($report in $reports) {
                $destDir = Join-Path -Path $tempDir -ChildPath $report.Name
                Copy-Item -Path $report.FullName -Destination $destDir -Recurse -Force -ErrorAction SilentlyContinue
                $anyFiles = $true
            }
        }

        # Also pull Application Error events (Event ID 1000) from the last 7 days
        try {
            $appErrors = Get-WinEvent -FilterHashtable @{
                LogName   = "Application"
                Id        = 1000
                StartTime = $threshold
            } -ErrorAction Stop

            if ($appErrors) {
                $appErrors | Format-List * | Out-String -Width 32767 |
                    Out-File -FilePath "$tempDir\AppError_Events.txt" -Encoding utf8 -Force
                Write-Host "Exported $($appErrors.Count) Application Error event(s)."
                $anyFiles = $true
            }
        } catch {
            Write-Host "No Application Error events (ID 1000) found in the last 7 days."
        }

        if ($anyFiles) {
            $zipFilePath = "$outputDir\AppCrashLogs.zip"
            Compress-Archive -Path "$tempDir\*" -DestinationPath $zipFilePath -Force
            Write-Host "App crash logs zipped successfully: $zipFilePath"
        } else {
            Write-Host "No app crash data found in the last 7 days."
        }
    } finally {
        Remove-Item -Path $tempDir -Recurse -Force -ErrorAction SilentlyContinue
    }
}

