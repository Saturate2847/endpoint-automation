function SystemInfoLogs {
    Ensure-LogDir

    $logFilePath = "$outputDir\SystemInfo.txt"
    $output      = [System.Text.StringBuilder]::new()

    $null = $output.AppendLine("SYSTEM INFORMATION REPORT")
    $null = $output.AppendLine("Generated: $(Get-Date)")
    $null = $output.AppendLine("=" * 60)
    $null = $output.AppendLine()

    $sections = [ordered]@{
        "OS & COMPUTER INFO" = {
            $cs = Get-CimInstance Win32_ComputerSystem
            $os = Get-CimInstance Win32_OperatingSystem
            $bios = Get-CimInstance Win32_BIOS
            [PSCustomObject]@{
                ComputerName    = $cs.Name
                Manufacturer    = $cs.Manufacturer
                Model           = $cs.Model
                TotalRAM_GB     = [math]::Round($cs.TotalPhysicalMemory / 1GB, 2)
                OSName          = $os.Caption
                OSVersion       = $os.Version
                OSBuildNumber   = $os.BuildNumber
                OSArchitecture  = $os.OSArchitecture
                InstallDate     = $os.InstallDate
                LastBootUpTime  = $os.LastBootUpTime
                Uptime          = (Get-Date) - $os.LastBootUpTime
                BIOSVersion     = $bios.SMBIOSBIOSVersion
                SerialNumber    = $bios.SerialNumber
            } | Format-List | Out-String -Width 32767
        }
        "CPU" = {
            Get-CimInstance Win32_Processor |
                Format-List Name, NumberOfCores, NumberOfLogicalProcessors, MaxClockSpeed, CurrentClockSpeed, LoadPercentage |
                Out-String -Width 32767
        }
        "RAM MODULES" = {
            Get-CimInstance Win32_PhysicalMemory |
                Format-Table BankLabel, Capacity, Speed, Manufacturer, PartNumber -AutoSize |
                Out-String -Width 32767
        }
        "INSTALLED HOTFIXES (last 90 days)" = {
            $threshold = (Get-Date).AddDays(-90)
            Get-HotFix | Where-Object { $_.InstalledOn -ge $threshold } |
                Sort-Object InstalledOn -Descending |
                Format-Table HotFixID, Description, InstalledOn, InstalledBy -AutoSize |
                Out-String -Width 32767
        }
        "LOCAL USERS" = {
            Get-LocalUser | Format-Table Name, Enabled, LastLogon, PasswordLastSet, PasswordRequired -AutoSize |
                Out-String -Width 32767
        }
        "STARTUP PROGRAMS" = {
            Get-CimInstance Win32_StartupCommand |
                Format-Table Name, Command, Location, User -AutoSize |
                Out-String -Width 32767
        }
        "RUNNING SERVICES (non-MS)" = {
            Get-Service | Where-Object { $_.Status -eq "Running" } |
                Sort-Object DisplayName |
                Format-Table DisplayName, Name, Status, StartType -AutoSize |
                Out-String -Width 32767
        }
        "FAILED SERVICES" = {
            Get-Service | Where-Object { $_.StartType -ne "Disabled" -and $_.Status -ne "Running" -and $_.StartType -eq "Automatic" } |
                Format-Table DisplayName, Name, Status, StartType -AutoSize |
                Out-String -Width 32767
        }
        "ENVIRONMENT VARIABLES" = {
            [System.Environment]::GetEnvironmentVariables("Machine") |
                Out-String -Width 32767
        }
    }

    foreach ($section in $sections.Keys) {
        $null = $output.AppendLine("=" * 60)
        $null = $output.AppendLine($section)
        $null = $output.AppendLine("=" * 60)
        try {
            $result = & $sections[$section]
            $null = $output.AppendLine(($result | Out-String))
        } catch {
            $null = $output.AppendLine("ERROR: $($_.Exception.Message)")
        }
        $null = $output.AppendLine()
    }

    $output.ToString() | Out-File -FilePath $logFilePath -Encoding utf8 -Force
    Write-Host "System info report saved to: $logFilePath"
}

